{
  "manifest_version": 3,
  "name": "自定义新标签页",
  "version": "1.2.2",
  "description": "带有背景轮播和搜索功能的自定义新标签页。v1.2.2：新增搜索框文字颜色选择器。",
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "icons": {
    "128": "icon/logo-T.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["image-list.json", "images/*"],
      "matches": ["<all_urls>"]
    }
  ]
}