{
  "manifest_version": 3,
  "name": "自定义新标签页",
  "version": "1.2.3",
  "description": "带有背景轮播和搜索功能的自定义新标签页。v1.2.3：设置面板视觉与交互全面优化；修复折叠图标与恢复默认配置 bug。",
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "icons": {
    "128": "icon/logo-T.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["image-list.json", "images/*"],
      "matches": ["<all_urls>"]
    }
  ]
}